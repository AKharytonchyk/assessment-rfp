@startuml c4-component-pipeline
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
left to right direction

skinparam nodesep 18
skinparam ranksep 36
skinparam defaultFontSize 14
skinparam linetype ortho
skinparam roundCorner 6

title Enterprise Data Platform - Reference Pipeline (C4 Component)

System_Ext(source, "Source System", "CRM · ERP · HRIS\nFiles · DMS CDC")

Component(ingest, "Ingest + PII Classify", "Glue / Lambda + Macie", "edp_common connectors\nContract-validated\nBronze + Macie tag")

Component(dq1, "Bronze DQ", "Lambda + GX", "Schema check\nRecord count")

Component(silver, "Silver Transform", "Glue PySpark + Iceberg", "Cast · dedup · PII mask\nCRS + H3 · MERGE INTO")

Component(dq2, "Silver DQ", "Lambda + GX", "Completeness ≥ 95%\nSpatial · schema")

Component(gold, "Gold Build + ER", "Glue + AWS ER", "SCD2 · cross-domain\ndim_spatial_entity")

Component(dq3, "Gold DQ", "GX + Soda", "Completeness ≥ 99%\nTimeliness + anomaly")

Component(notify, "Notify + Replay", "Lambda + SFn", "Events · records\nReplay from snapshot")

Component(quarantine, "Quarantine", "Lambda + PII scrub", "Tokenize before\nS3 Rejected")

' ── Main horizontal flow ──────────────────────────────────
source --> ingest
ingest --> dq1
dq1 --> silver : Pass
silver --> dq2
dq2 --> gold : Pass
gold --> dq3
dq3 --> notify : Pass

' ── Error branch downward ─────────────────────────────────
dq2 --> quarantine : Fail

' OpenLineage + CloudWatch emit on every stage (cross-cutting — noted on slide)

@enduml
